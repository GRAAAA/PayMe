{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "payme",
  "main": "src/index.js",
  "compatibility_date": "2026-06-29",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "vars": {
    "GEMINI_MODEL": "gemini-3.1-flash-lite",
    "MAX_IMAGE_BYTES": "1200000"
  }
}
